{
  "name": "paper-dashboard-react",
  "version": "1.3.2",
  "private": true,
  "dependencies": {
    "ajv": "^6.14.0",
    "ajv-keywords": "^3.5.2",
    "axios": "^1.6.8",
    "bootstrap": "4.6.2",
    "chart.js": "3.9.1",
    "perfect-scrollbar": "1.5.5",
    "react": "^17.0.2",
    "react-chartjs-2": "3.3.0",
    "react-circular-progressbar": "^2.1.0",
    "react-d3-speedometer": "^1.0.2",
    "react-dom": "^17.0.2",
    "react-notification-alert": "0.0.13",
    "react-router-dom": "6.11.1",
    "react-scripts": "^5.0.1",
    "reactstrap": "8.10.0",
    "sass": "1.62.1",
    "express": "^4.21.2"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "install:clean": "rm -rf node_modules/ && rm -rf package-lock.json && npm install && npm start",
    "compile-sass": "node-sass src/assets/scss/paper-dashboard.scss src/assets/css/paper-dashboard.css",
    "minify-sass": "node-sass src/assets/scss/paper-dashboard.scss src/assets/css/paper-dashboard.min.css --output-style compressed",
    "map-sass": "node-sass src/assets/scss/paper-dashboard.scss src/assets/css/paper-dashboard.css --source-map true",
    "backend": "node server.js"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ],
  "optionalDependencies": {
    "typescript": "5.0.4"
  },
  "overrides": {
    "svgo": "3.0.2",
    "fsevents": "2.3.2",
    "chokidar": "3.5.3",
    "@babel/core": "7.18.6"
  }
}
